# ============================================
# Configuração do Banco de Dados MySQL
# ============================================
# Copie este arquivo para .env e preencha com suas credenciais
# O arquivo .env NÃO deve ser versionado (.gitignore)

DB_HOST=localhost
DB_PORT=3306
DB_NAME=tcc
DB_USERNAME=root
DB_PASSWORD=SUA_SENHA_AQUI

# ============================================
# Seeder de dados de desenvolvimento
# ============================================
# "true" ativa o seeder (10 clientes, 10 trajes, 10 medidas, 15 aluguéis, 10 devoluções).
# Idempotente: só popula se o banco estiver vazio.
SEEDER_ENABLED=true
